{UTF-8}
Children = INTEG ( Births - Maturation to Youth, 1000 )
	~ Person
	~ 老化链：人口按年龄分级流动，多级库存流水通用结构。适用于人口、产品批次、物料在制品。
	|

Youth = INTEG ( Maturation to Youth - Maturation to Adult, 800 )
	~ Person
	~	|

Adults = INTEG ( Maturation to Adult - Maturation to Elderly, 1500 )
	~ Person
	~	|

Elderly = INTEG ( Maturation to Elderly - Deaths, 600 )
	~ Person
	~	|

Births = Adults * Birth Rate
	~ Person/Year
	~ 新生由成年人口决定
	|

Maturation to Youth = Children / Childhood Duration
	~ Person/Year
	~ 儿童到青年的成熟流
	|

Maturation to Adult = Youth / Youth Duration
	~ Person/Year
	~	|

Maturation to Elderly = Adults / Adult Duration
	~ Person/Year
	~	|

Deaths = Elderly / Elderly Duration
	~ Person/Year
	~	|

Birth Rate = 0.04
	~ 1/Year
	~	|

Childhood Duration = 15
	~ Year
	~	|

Youth Duration = 15
	~ Year
	~	|

Adult Duration = 30
	~ Year
	~	|

Elderly Duration = 10
	~ Year
	~	|

INITIAL TIME = 0
	~ Year
	~	|

FINAL TIME = 100
	~ Year
	~	|

TIME STEP = 0.5
	~ Year
	~	|

SAVEPER = TIME STEP
	~ Year
	~	|

