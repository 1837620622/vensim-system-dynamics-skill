Workforce = INTEG ( Hiring - Quitting, 100 )
	~ Person
	~ 
	|
Hiring = 5
	~ Person/Month
	~ 
	|
Quitting = Workforce * Quit Rate
	~ Person/Month
	~ 
	|
Quit Rate = 0.02
	~ 1/Month
	~ 
	|
Experience = INTEG ( Experience Gain - Experience Loss, 500 )
	~ Person*Month
	~ 
	|
Experience Gain = Hiring * Avg Tenure
	~ Person*Month/Month
	~ 
	|
Experience Loss = Quitting * Avg Tenure
	~ Person*Month/Month
	~ 
	|
Avg Tenure = 60
	~ Month
	~ 
	|
Avg Experience = IF THEN ELSE( Workforce > 0, Experience / Workforce, 0 )
	~ Month
	~ 
	|
INITIAL TIME = 0
	~ Month
	~ 
	|
FINAL TIME = 120
	~ Month
	~ 
	|
TIME STEP = 0.25
	~ Month
	~ 
	|
SAVEPER = TIME STEP
	~ Month
	~ 
	|
