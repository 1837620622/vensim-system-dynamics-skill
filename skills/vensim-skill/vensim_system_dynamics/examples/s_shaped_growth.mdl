Adopters = INTEG ( Adoption Rate - Abandonment Rate, 10 )
	~ Person
	~ 
	|
Potential Adopters = INTEG ( - Adoption Rate, 1000 )
	~ Person
	~ 
	|
Adoption Rate = Potential Adopters * Adoption Fraction * Contact Rate * Adopters / Total Population
	~ Person/Month
	~ 
	|
Abandonment Rate = Adopters * Abandonment Fraction
	~ Person/Month
	~ 
	|
Adoption Fraction = 0.37
	~ Dmnl
	~ 
	|
Contact Rate = 10
	~ 1/Month
	~ 
	|
Abandonment Fraction = 0.02
	~ 1/Month
	~ 
	|
Total Population = 1010
	~ Person
	~ 
	|
INITIAL TIME = 0
	~ Month
	~ 
	|
FINAL TIME = 120
	~ Month
	~ 
	|
TIME STEP = 0.25
	~ Month
	~ 
	|
SAVEPER = TIME STEP
	~ Month
	~ 
	|
