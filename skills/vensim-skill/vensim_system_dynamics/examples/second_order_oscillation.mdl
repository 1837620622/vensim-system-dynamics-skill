{UTF-8}
Inventory = INTEG ( Production - Sales, 100 )
	~ Unit
	~ 二阶振荡：库存-劳动力调整产生振荡。需求冲击后库存与劳动力相互追赶，形成衰减振荡。
	|

Workforce = INTEG ( Net Hiring, 10 )
	~ Person
	~ 劳动力库存
	|

Production = Workforce * Productivity
	~ Unit/Month
	~ 产量由劳动力决定
	|

Sales = 10 + STEP ( 5, 5 )
	~ Unit/Month
	~ 外生需求，第5月阶跃上升制造冲击
	|

Target Inventory = 100
	~ Unit
	~ 目标库存
	|

Inventory Adjustment Time = 2
	~ Month
	~ 库存调整时间
	|

Desired Production = Sales + ( Target Inventory - Inventory ) / Inventory Adjustment Time
	~ Unit/Month
	~ 期望产量=满足需求+补库存
	|

Productivity = 10
	~ Unit/Person/Month
	~ 人均产出
	|

Desired Workforce = Desired Production / Productivity
	~ Person
	~ 期望劳动力
	|

Workforce Adjustment Time = 3
	~ Month
	~ 劳动力调整时间
	|

Net Hiring = ( Desired Workforce - Workforce ) / Workforce Adjustment Time
	~ Person/Month
	~ 净雇佣率（正为雇佣，负为解雇）
	|

INITIAL TIME = 0
	~ Month
	~	|

FINAL TIME = 60
	~ Month
	~	|

TIME STEP = 0.25
	~ Month
	~	|

SAVEPER = TIME STEP
	~ Month
	~	|

