Input Rate = 100 + 20 * SIN( 2 * 3.14159 / 12 * Time )
	~ Unit/Month
	~ 
	|
Smoothed Input = SMOOTH( Input Rate, Smoothing Time )
	~ Unit/Month
	~ 
	|
Smoothing Time = 6
	~ Month
	~ 
	|
Level = INTEG ( Input Rate - Smoothed Input, 0 )
	~ Unit
	~ 
	|
INITIAL TIME = 0
	~ Month
	~ 
	|
FINAL TIME = 60
	~ Month
	~ 
	|
TIME STEP = 0.25
	~ Month
	~ 
	|
SAVEPER = TIME STEP
	~ Month
	~ 
	|
