{UTF-8}
Capital = INTEG ( Investment - Depreciation, 100 )
	~ Dollar
	~ 一阶正反馈：复利/指数增长。资本再投资产生指数扩张，通用增长结构。
	|

Investment = Capital * Reinvestment Rate
	~ Dollar/Year
	~ 每期再投资额
	|

Depreciation = Capital / Capital Lifetime
	~ Dollar/Year
	~ 资本折旧
	|

Reinvestment Rate = 0.12
	~ 1/Year
	~ 再投资比例
	|

Capital Lifetime = 20
	~ Year
	~ 资本使用寿命
	|

Net Growth Rate = Reinvestment Rate - 1 / Capital Lifetime
	~ 1/Year
	~ 净增长率（>0 指数增长，<0 衰减）
	|

INITIAL TIME = 0
	~ Year
	~	|

FINAL TIME = 50
	~ Year
	~	|

TIME STEP = 0.25
	~ Year
	~	|

SAVEPER = TIME STEP
	~ Year
	~	|

