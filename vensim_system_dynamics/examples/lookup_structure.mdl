Price = 50
	~ Dollar/Unit
	~ 
	|
Demand = WITH LOOKUP( Price, ( [0,0)-(100,1000)], (0,950), (20,800), (40,600), (60,400), (80,200), (100,50) )
	~ Unit/Month
	~ 
	|
Supply = WITH LOOKUP( Price, ( [0,0)-(100,1000)], (0,50), (20,200), (40,400), (60,600), (80,800), (100,950) )
	~ Unit/Month
	~ 
	|
Price Change = ( Demand - Supply ) * Adjustment Rate
	~ Dollar/Unit/Month
	~ 
	|
Adjustment Rate = 0.1
	~ 1/Month
	~ 
	|
Price = INTEG ( Price Change, 50 )
	~ Dollar/Unit
	~ 
	|
INITIAL TIME = 0
	~ Month
	~ 
	|
FINAL TIME = 60
	~ Month
	~ 
	|
TIME STEP = 0.25
	~ Month
	~ 
	|
SAVEPER = TIME STEP
	~ Month
	~ 
	|
