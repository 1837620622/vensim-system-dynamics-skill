Revenue = Sales * Price
	~ Dollar/Month
	~ 
	|
Sales = 100
	~ Unit/Month
	~ 
	|
Price = 50
	~ Dollar/Unit
	~ 
	|
Cost = Revenue * Cost Fraction
	~ Dollar/Month
	~ 
	|
Cost Fraction = 0.6
	~ Dmnl
	~ 
	|
Profit = Revenue - Cost
	~ Dollar/Month
	~ 
	|
Investment = Profit * Reinvestment Rate
	~ Dollar/Month
	~ 
	|
Reinvestment Rate = 0.3
	~ Dmnl
	~ 
	|
Capital = INTEG ( Investment - Depreciation, 10000 )
	~ Dollar
	~ 
	|
Depreciation = Capital / Capital Lifetime
	~ Dollar/Month
	~ 
	|
Capital Lifetime = 120
	~ Month
	~ 
	|
Productivity = 0.01
	~ Unit/Dollar/Month
	~ 
	|
Capacity = Capital * Productivity
	~ Unit/Month
	~ 
	|
INITIAL TIME = 0
	~ Month
	~ 
	|
FINAL TIME = 120
	~ Month
	~ 
	|
TIME STEP = 0.25
	~ Month
	~ 
	|
SAVEPER = TIME STEP
	~ Month
	~ 
	|
