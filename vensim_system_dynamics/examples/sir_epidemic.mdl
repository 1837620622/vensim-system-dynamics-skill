{UTF-8}
Susceptible = INTEG ( - Infection Rate, 990 )
	~ Person
	~ SIR 传染病模型：易感-感染-康复三库存。流行病/谣言扩散/创新采纳通用结构。
	|

Infected = INTEG ( Infection Rate - Recovery Rate, 10 )
	~ Person
	~	|

Recovered = INTEG ( Recovery Rate, 0 )
	~ Person
	~	|

Infection Rate = Susceptible * Infected * Infection Probability / Total Population
	~ Person/Day
	~ 接触传染率，正反馈驱动疫情爆发
	|

Recovery Rate = Infected / Illness Duration
	~ Person/Day
	~ 康复率，负反馈使疫情消退
	|

Total Population = 1000
	~ Person
	~	|

Infection Probability = 0.3
	~ 1/Day
	~ 每次接触传染概率
	|

Illness Duration = 14
	~ Day
	~ 病程
	|

Recovered Fraction = Recovered / Total Population
	~ Dmnl
	~ 康复比例（疫情结束时趋近1）
	|

INITIAL TIME = 0
	~ Day
	~	|

FINAL TIME = 100
	~ Day
	~	|

TIME STEP = 0.25
	~ Day
	~	|

SAVEPER = TIME STEP
	~ Day
	~	|

